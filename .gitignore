# Ignore everything in the project root by default
*

# Do not ignore .gitignore and README.md
!.gitignore
!README.md

# Do not ignore skills directory and its contents recursively
!skills/
!skills/**

# Ignore system metadata inside allowed directories
**/.DS_Store
**/Thumbs.db
**/__pycache__/
**/*.py[cod]
**/~$*
